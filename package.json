{
  "name": "@vuepress/monorepo",
  "version": "2.0.0-rc.30",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --stream build",
    "check-types": "vue-tsc --noEmit",
    "clean": "pnpm run --parallel --stream clean",
    "format": "oxfmt",
    "lint": "eslint . && oxfmt --check",
    "lint:fix": "eslint --fix . && oxfmt",
    "prepare": "husky",
    "release": "pnpm release:check && pnpm release:version",
    "release:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:check": "pnpm clean && pnpm build && pnpm check-types && pnpm lint && pnpm test",
    "release:version": "bumpp -r --execute=\"pnpm release:changelog\" --commit \"build: publish v%s\" --all",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "pnpm --filter e2e e2e:dev && pnpm --filter e2e e2e:build",
    "test:e2e:webpack": "pnpm --filter e2e e2e:dev:webpack && pnpm --filter e2e e2e:build:webpack",
    "test:unit": "vitest run",
    "test:unit:cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@types/node": "^24.12.3",
    "@types/webpack-env": "^1.18.8",
    "@vitest/coverage-istanbul": "catalog:vite",
    "@vuepress/eslint-config": "^8.2.0",
    "@vuepress/oxfmt-config": "^8.2.0",
    "@vuepress/tsconfig": "^8.0.0",
    "bumpp": "^11.1.0",
    "conventional-changelog": "^7.2.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.48.0",
    "rimraf": "^6.1.3",
    "taze": "^19.11.0",
    "tsdown": "catalog:vite",
    "typescript": "^6.0.3",
    "vite": "catalog:vite",
    "vitest": "catalog:vite",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.!(cjs|js|ts|vue)": "oxfmt --no-error-on-unmatched-pattern",
    "*.(cjs|js|ts|vue)": [
      "eslint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@11.0.8"
}
